@model List<OnlineVotingSystem.Models.ResultViewModel>
@using System.Linq
@using System.Collections.Generic
@{
    ViewBag.Title = "Election Results";
}

@Html.ActionLink("← Back to Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-back" })

<div class="page-header">
    <h2>Election Results</h2>
</div>

<div class="form-container">
    @using (Html.BeginForm("Results", "Admin", FormMethod.Post))
    {
        <div class="form-group">
            <label for="electionId">Select Election:</label>
            @Html.DropDownList("electionId", (SelectList)ViewBag.Elections, "-- Select Election --", new { @class = "form-control", onchange = "this.form.submit();" })
        </div>
    }
</div>

@if (ViewBag.ElectionTitle != null)
{
    <div class="page-header" style="background: linear-gradient(135deg, #17a2b8, #138496);">
        <h3 style="margin: 0;">Results for: @ViewBag.ElectionTitle</h3>
    </div>

    <div class="data-grid">
        @{
            // safe total calculation: handles null model
            int totalVotes = Model?.Sum(x => x.VoteCount) ?? 0;
        }

        @if (Model != null && Model.Count > 0)
        {
            <table>
                <thead>
                    <tr>
                        <th>Candidate Name</th>
                        <th>Vote Count</th>
                        <th>Percentage</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CandidateName</td>
                            <td>@item.VoteCount</td>
                            <td>
                                @(
                                    totalVotes > 0
                                        ? string.Format("{0:0.##}%", Math.Round((double)item.VoteCount / totalVotes * 100, 2))
                                        : "0%"
                                )
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
            <div style="margin-top: 20px; padding: 15px; background: #f8f9fa; border-radius: 6px;">
                <strong>Total Votes Cast: @totalVotes</strong>
            </div>
        }
        else
        {
            <div class="no-data">
                <p>No votes recorded for this election yet.</p>
            </div>
        }
    </div>
}
