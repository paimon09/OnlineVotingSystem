@{
    ViewBag.Title = "Add Election";
}

@Html.ActionLink("← Back to Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-back" })

<div class="page-header">
    <h2>Add New Election</h2>
</div>

<div class="form-container">
    @using (Html.BeginForm("AddElection", "Admin", FormMethod.Post))
    {
        <div class="form-group">
            <label for="title">Election Title:</label>
            <input type="text" name="title" id="title" class="form-control" required />
        </div>

        <div class="form-group">
            <label for="startDate">Start Date:</label>
            <input type="date" name="startDate" id="startDate" class="form-control" required />
        </div>

        <div class="form-group">
            <label for="endDate">End Date:</label>
            <input type="date" name="endDate" id="endDate" class="form-control" required />
        </div>

        <input type="submit" value="Create Election" class="btn btn-primary" />
        @Html.ActionLink("Cancel", "Dashboard", "Admin", null, new { @class = "btn btn-secondary" })
    }
</div>

@if (ViewBag.Message != null)
{
    <div class="alert alert-success">
        @ViewBag.Message
    </div>
}
