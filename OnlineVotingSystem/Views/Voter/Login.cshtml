@{
    ViewBag.Title = "Voter Login";
}

<style>
    body {
        background: linear-gradient(120deg, #0f2027, #2c5364);
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI', Arial, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .portal-container {
        width: 100%;
        max-width: 400px;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 6px 32px rgba(44, 83, 100, 0.18), 0 1.5px 4px rgba(0, 0, 0, 0.06);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .portal-header {
        background: linear-gradient(90deg, #11998e, #38ef7d);
        color: #fff;
        text-align: center;
        padding: 2rem 1rem 1.2rem;
        font-size: 1.6rem;
        font-weight: 700;
        border-bottom-left-radius: 32px 24px;
        border-bottom-right-radius: 32px 24px;
    }

    .portal-logo {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        margin-bottom: 0.4rem;
        object-fit: cover;
        background-color: #e0f7fa;
        box-shadow: 0 2px 8px rgba(17, 153, 142, 0.14);
    }

    .portal-form {
        padding: 1.6rem;
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .portal-label {
        font-weight: 500;
        margin-bottom: 0.3rem;
        color: #333;
    }

    .portal-input {
        padding: 10px 14px;
        border: 1.5px solid #17b978;
        border-radius: 6px;
        background: #f5f7fa;
        font-size: 1rem;
        transition: 0.15s ease;
    }

    .portal-input:focus {
        outline: none;
        border-color: #11998e;
        background: #e7f8f2;
    }

    .portal-submit {
        background: linear-gradient(90deg, #11998e, #38ef7d);
        border: none;
        color: white;
        padding: 12px;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s ease;
    }

    .portal-submit:hover {
        background: linear-gradient(90deg, #38ef7d, #11998e);
    }

    .portal-secondary {
        display: inline-block;
        text-align: center;
        background: #6c757d;
        color: #fff;
        padding: 10px 14px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        margin-top: 8px;
        border: none; /* allow use on <button> */
        cursor: pointer;
    }

    .portal-secondary:hover {
        background: #5a6268;
        text-decoration: none;
        color: #fff;
    }

    .portal-message {
        text-align: center;
        margin-top: 0.5rem;
        color: #d32f2f;
        font-weight: 500;
        min-height: 1.2rem;
    }

    @@media (max-width: 500px) {
        .portal-container { margin: 1rem; }
        .portal-form { padding: 1rem; }
    }
</style>

<div class="portal-container">
    <div class="portal-header">
        <img src="~/images/AdminLogin.jpg" alt="Voter Portal Logo" class="portal-logo" />
        Voter Login
    </div>

    <div class="portal-form">
        @using (Html.BeginForm("Login", "Voter", FormMethod.Post))
        {
            <div class="form-group">
                <label class="portal-label" for="username">Username</label>
                <input type="text" name="username" id="username" class="portal-input" required autocomplete="username" />
            </div>

            <div class="form-group">
                <label class="portal-label" for="password">Password</label>
                <input type="password" name="password" id="password" class="portal-input" required autocomplete="current-password" />
            </div>

            <button type="submit" class="portal-submit">Login</button>
        }

    <div style="text-align:center; margin-top:8px;">
        <a href="@Url.Action("Login", "Admin")" class="" style="display:inline-block;">
            Go to Admin Login Page
        </a>
    </div>

        <div class="portal-message">@ViewBag.Message</div>
    </div>
</div>
